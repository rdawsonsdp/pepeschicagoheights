# Shopify Configuration for Urban Bistro
# Copy this file to .env.local and fill in your API token

# Shopify Store Domain
SHOPIFY_STORE_DOMAIN=urbanbistro.myshopify.com

# Shopify Admin API Access Token
# Get this from: https://admin.shopify.com/store/urbanbistro/settings/apps/development
# Create a new app > Configure Admin API scopes > Install app > Get token
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx

# Collection handle for catering products
# Create this collection at: https://admin.shopify.com/store/urbanbistro/collections
SHOPIFY_CATERING_COLLECTION_HANDLE=catering-products

# Base URL (for production, update to your domain)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── NextAuth (Admin Authentication) ──────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google emails allowed to access /admin
ADMIN_EMAILS=owner@example.com,manager@example.com
